generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  DIRECTOR
  ACCOUNTS
}

enum VoucherStatus {
  DRAFT
  SUBMITTED
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

model User {
  id               String         @id @default(uuid())
  email            String         @unique
  passwordHash     String
  name             String
  role             Role           @default(EMPLOYEE)
  department       String
  signaturePath    String?
  isActive         Boolean        @default(true)
  deletedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  vouchers         Voucher[]      @relation("VoucherOwner")
  approvedVouchers Voucher[]      @relation("VoucherApprover")
  refreshTokens    RefreshToken[]
  @@index([role, department])
  @@index([deletedAt])
}

model Voucher {
  id                    String        @id @default(uuid())
  voucherNumber         String        @unique
  expenseTitle          String
  category              String
  department            String
  amount                Decimal       @db.Decimal(12, 2)
  expenseDate           DateTime      @db.Date
  description           String?
  status                VoucherStatus @default(DRAFT)
  employeeSignaturePath String?
  directorSignaturePath String?
  rejectionReason       String?
  submittedAt           DateTime?
  approvedAt            DateTime?
  deletedAt             DateTime?
  ownerId               String
  approverId            String?
  owner                 User          @relation("VoucherOwner", fields: [ownerId], references: [id])
  approver              User?         @relation("VoucherApprover", fields: [approverId], references: [id])
  attachments           Attachment[]
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  @@index([status, department, createdAt])
  @@index([ownerId, status])
  @@index([expenseDate])
  @@index([deletedAt])
}

model Attachment {
  id           String   @id @default(uuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  voucherId    String
  voucher      Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@index([userId, expiresAt])
}

model VoucherSequence {
  year  Int @id
  value Int @default(0)
}
