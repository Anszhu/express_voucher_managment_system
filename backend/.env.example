NODE_ENV=development
PORT=4000
APP_VERSION=1.0.0
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/voucher_db?schema=public"
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=replace-with-a-different-long-random-refresh-secret-at-least-32-chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
CORS_ORIGIN=http://localhost:5173
MAX_UPLOAD_MB=2
LOG_LEVEL=info
