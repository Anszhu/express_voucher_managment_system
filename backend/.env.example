# =============================================================================
# Express Voucher Management System — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values before running the server.
#   cp .env.example .env
# =============================================================================

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://voucher:voucher@localhost:5432/voucher_db?schema=public"

# ─── Authentication ──────────────────────────────────────────────────────────
# JWT signing secrets (required, minimum 32 characters each).
JWT_ACCESS_SECRET="change-me-to-a-random-64-character-string"
JWT_REFRESH_SECRET="change-me-to-another-random-64-character-string"

# Token expiration durations (optional, defaults shown below).
# Uses vercel/ms format: https://www.npmjs.com/package/ms
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="7d"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV="development"
APP_VERSION="1.0.0"
LOG_LEVEL="info"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
CORS_ORIGIN="http://localhost:5173,http://localhost:3000,http://localhost:8080"

# ─── Uploads ──────────────────────────────────────────────────────────────────
# Maximum upload file size in megabytes.
MAX_UPLOAD_MB=2

# ─── Production Overrides (example) ──────────────────────────────────────────
# DATABASE_URL="postgresql://user:password@production-host:5432/production-db?schema=public"
# NODE_ENV="production"
# CORS_ORIGIN="https://your-frontend-domain.vercel.app"
# LOG_LEVEL="warn"
